{
  "name": "holocard",
  "version": "0.1.0",
  "description": "Open holographic card renderer and managed Cloudflare creator.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev --port 8789",
    "build": "vite build && vite build --config vite.mcp.config.ts",
    "check": "tsc --noEmit",
    "test": "bun test",
    "deploy": "bun run build && wrangler deploy",
    "deploy:dry": "bun run build && wrangler deploy --dry-run",
    "types": "wrangler types",
    "db:local": "wrangler d1 migrations apply holocard --local",
    "db:remote": "wrangler d1 migrations apply holocard --remote",
    "card:generate": "bun run scripts/generate-card.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "hono": "^4.12.30",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@fontsource-variable/atkinson-hyperlegible-next": "^5.2.6",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-singlefile": "^2.3.3",
    "wrangler": "^4.112.0"
  }
}
