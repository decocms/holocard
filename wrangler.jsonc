{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "holocard",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "PUBLIC_ORIGIN": "https://holocard.page",
    "CREATE_MODEL": "@cf/openai/gpt-oss-120b",
    "REVISION_MODEL": "@cf/openai/gpt-oss-120b",
    "DAILY_CREATE_LIMIT": "5"
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*", "/mcp", "/mcp/*", "/media/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "holocard",
      "migrations_dir": "./migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "CARDS",
      "bucket_name": "holocard-cards"
    }
  ],
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
